{% doc %}
  @prompt
    guaranteed safe checkout widget with visa mastercard and meeza 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-safe-checkout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-safe-checkout__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-safe-checkout__icons-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-safe-checkout__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: auto;
    opacity: {{ block.settings.icon_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-safe-checkout__icon-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-safe-checkout-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-safe-checkout__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-safe-checkout__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-safe-checkout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-safe-checkout__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </div>
  {% endif %}

  <div class="ai-safe-checkout__icons-{{ ai_gen_id }}">
    <svg class="ai-safe-checkout__icon-{{ ai_gen_id }}" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="48" height="32" rx="4" fill="#1434CB"/>
      <path d="M20.5 22L14 15.5L15.5 14L20.5 19L32.5 7L34 8.5L20.5 22Z" fill="white"/>
      <path d="M18 10H14V12H18V10Z" fill="white"/>
      <path d="M34 10H30V12H34V10Z" fill="white"/>
      <path d="M18 20H14V22H18V20Z" fill="white"/>
      <path d="M34 20H30V22H34V20Z" fill="white"/>
    </svg>

    <svg class="ai-safe-checkout__icon-{{ ai_gen_id }}" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="48" height="32" rx="4" fill="#EB001B"/>
      <circle cx="18" cy="16" r="10" fill="#FF5F00"/>
      <circle cx="30" cy="16" r="10" fill="#F79E1B"/>
      <path d="M24 8C21.5 10 20 13 20 16C20 19 21.5 22 24 24C26.5 22 28 19 28 16C28 13 26.5 10 24 8Z" fill="#FF5F00"/>
    </svg>

    <svg class="ai-safe-checkout__icon-{{ ai_gen_id }}" viewBox="0 0 48 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="48" height="32" rx="4" fill="#00A651"/>
      <path d="M14 16L18 12V20L14 16Z" fill="white"/>
      <path d="M34 16L30 12V20L34 16Z" fill="white"/>
      <rect x="18" y="14" width="12" height="4" fill="white"/>
      <path d="M24 10C19.6 10 16 13.6 16 18H20C20 15.8 21.8 14 24 14C26.2 14 28 15.8 28 18H32C32 13.6 28.4 10 24 10Z" fill="white"/>
    </svg>
  </div>
</div>

{% schema %}
{
  "name": "Safe checkout",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Guaranteed Safe Checkout"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing below",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Payment icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "icon_opacity",
      "label": "Icon opacity",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    }
  ],
  "presets": [
    {
      "name": "Safe checkout"
    }
  ]
}
{% endschema %}