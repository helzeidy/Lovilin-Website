{% doc %}
  @prompt
    videos carousel
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-video-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: 32px;
  }

  .ai-video-carousel__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
  }

  .ai-video-carousel__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-video-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-video-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .ai-video-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 calc(100% / {{ block.settings.slides_per_view }} - {{ block.settings.gap }}px * ({{ block.settings.slides_per_view }} - 1) / {{ block.settings.slides_per_view }});
    min-width: 0;
  }

  .ai-video-carousel__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: {{ block.settings.video_background }};
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-carousel__video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-video-carousel__caption-{{ ai_gen_id }} {
    margin-top: 12px;
    font-size: {{ block.settings.caption_size }}px;
    color: {{ block.settings.caption_color }};
    text-align: {{ block.settings.caption_alignment }};
  }

  .ai-video-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 24px;
  }

  .ai-video-carousel__button-{{ ai_gen_id }} {
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_color }};
  }

  .ai-video-carousel__button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-carousel__button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.button_size }}px * 0.5);
    height: calc({{ block.settings.button_size }}px * 0.5);
  }

  .ai-video-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .ai-video-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    width: 24px;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 calc(100% / {{ block.settings.slides_per_view_mobile }} - {{ block.settings.gap }}px * ({{ block.settings.slides_per_view_mobile }} - 1) / {{ block.settings.slides_per_view_mobile }});
    }

    .ai-video-carousel__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-video-carousel__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }}
  class="ai-video-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-video-carousel__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-video-carousel__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <div class="ai-video-carousel__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-video-carousel__container-{{ ai_gen_id }}">
    <div class="ai-video-carousel__track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign caption_key = 'caption_' | append: i
          assign video = block.settings[video_key]
          assign caption = block.settings[caption_key]
        %}

        {% if video != blank %}
          <div class="ai-video-carousel__slide-{{ ai_gen_id }}">
            <div class="ai-video-carousel__video-wrapper-{{ ai_gen_id }}">
              {{ video | video_tag: autoplay: block.settings.video_autoplay, loop: block.settings.video_loop, muted: block.settings.video_muted, controls: block.settings.video_controls, class: 'ai-video-carousel__video-' | append: ai_gen_id }}
            </div>
            {% if caption != blank %}
              <div class="ai-video-carousel__caption-{{ ai_gen_id }}">{{ caption }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if block.settings.show_controls %}
    <div class="ai-video-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-video-carousel__button-{{ ai_gen_id }} ai-video-carousel__prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      {% if block.settings.show_dots %}
        <div class="ai-video-carousel__dots-{{ ai_gen_id }}"></div>
      {% endif %}

      <button
        class="ai-video-carousel__button-{{ ai_gen_id }} ai-video-carousel__next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-video-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-video-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-video-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-video-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-video-carousel__dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.slidesPerView = this.getSlidesPerView();
        this.totalSlides = this.slides.length;
        this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

        this.setupEventListeners();
        this.createDots();
        this.updateCarousel();

        if (this.dataset.autoplay === 'true') {
          this.startAutoplay();
        }

        window.addEventListener('resize', () => {
          this.slidesPerView = this.getSlidesPerView();
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
          this.currentIndex = Math.min(this.currentIndex, this.maxIndex);
          this.updateCarousel();
        });
      }

      getSlidesPerView() {
        return window.innerWidth < 750 ? {{ block.settings.slides_per_view_mobile }} : {{ block.settings.slides_per_view }};
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }
      }

      createDots() {
        if (!this.dotsContainer) return;

        const dotsCount = this.maxIndex + 1;
        for (let i = 0; i < dotsCount; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-video-carousel__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.gap }};
        const offset = -(this.currentIndex * (slideWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= this.maxIndex;
        }

        this.updateDots();
      }

      updateDots() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-video-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateCarousel();
          this.resetAutoplay();
        }
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
          this.updateCarousel();
          this.resetAutoplay();
        } else if (this.dataset.autoplay === 'true') {
          this.currentIndex = 0;
          this.updateCarousel();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateCarousel();
        this.resetAutoplay();
      }

      startAutoplay() {
        const speed = parseInt(this.dataset.autoplaySpeed) || 3000;
        this.autoplayInterval = setInterval(() => {
          this.next();
        }, speed);
      }

      resetAutoplay() {
        if (this.dataset.autoplay === 'true') {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>

