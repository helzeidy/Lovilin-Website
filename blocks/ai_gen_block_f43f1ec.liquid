      "label": "Width",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "color",
      "id": "modal_background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "modal_text_color",
      "label": "Text color",
      "default": "#071e85"
    },
    {
      "type": "color",
      "id": "modal_border_color",
