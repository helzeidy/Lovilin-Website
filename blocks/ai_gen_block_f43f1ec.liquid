{% doc %}
  @prompt
    a button with no details that open a modal i'll add all the required details inside the liquid code i just want a ready modal opener widget 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-modal-opener-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  {% comment %} .ai-modal-trigger-{{ ai_gen_id }} {
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-modal-trigger-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  } {% endcomment %}

  .plan .pie {
    display: inline-block;
    width: 34px;
    height: 34px;
    box-sizing: border-box;
    border: 2px solid #e6e6e6;
    border-radius: 50%;
    background-color: #071E85;
    margin-bottom: 10px;
}

.plan .pie.twenty {
    background-image: linear-gradient(162deg, transparent 50%, white 50%), linear-gradient(90deg, white 50%, transparent 50%) !important;
}

.plan .pie.fourty {
    background-image: linear-gradient(234deg, transparent 50%, white 50%), linear-gradient(90deg, white 50%, transparent 50%) !important;
}

.plan .pie.sixty {
    background-image: linear-gradient(126deg, transparent 50%, #071E85 50%), linear-gradient(90deg, white 50%, transparent 50%) !important;
}

.plan {
    display: flex;
    flex-direction: row;
    justify-content: flex-start;
    align-items: flex-start;
}

.plan .oval {
    width: 36px;
    height: 36px;
    margin-bottom: 10px;
}

.plan .vertical-line {
    flex-shrink: 0;
    width: 1px;
    height: 64px;
    border-radius: 1px;
    background-color: #d8d8d8;
    margin: 0 16px;
}

.plan .horizontal-line {
    width: 100%;
    height: 1px;
    border-radius: 1px;
    background-color: #d8d8d8;
    margin-top: 17px;
}

.modal-content {
  text-align: center;
}
.modal-content .steps {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
}

.modal-content .steps .step {
    display: flex;
    flex-direction: column;
    max-width: calc(100% / 3 - 20px);
}

.modal-container img {
    object-fit: contain;
}

  .ai-modal-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 9998;
  }

  .ai-modal-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-modal-container-{{ ai_gen_id }} {
    position: fixed;
    top: 55%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    width: 80%;
    max-width: 90vw;
    max-height: 80vh;
    background-color: {{ block.settings.modal_background_color }};
    border-radius: {{ block.settings.modal_border_radius }}px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 9999;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-modal-container-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, -50%) scale(1);
  }

  .ai-modal-header-{{ ai_gen_id }} {
    padding: 20px 24px;
    border-bottom: 1px solid {{ block.settings.modal_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ai-modal-header-{{ ai_gen_id }} .logo{
    max-width:120px;
  }

 .ai-modal-header-details-{{ ai_gen_id }}{
     display: flex;
    align-items: center;
    justify-content: space-between;
    flex-direction:column;
    gap:8px;
}

  .ai-modal-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.modal_title_size }}px;
    color: {{ block.settings.modal_text_color }};
  }

  .ai-modal-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.modal_text_color }};
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }

  .ai-modal-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-modal-body-{{ ai_gen_id }} {
    padding: 24px;
    overflow-y: auto;
    flex-grow: 1;
    color: {{ block.settings.modal_text_color }};
  }

  .ai-modal-footer-{{ ai_gen_id }} {
    padding: 20px 24px;
    border-top: 1px solid {{ block.settings.modal_border_color }};
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  @media screen and (max-width: 749px) {
    .ai-modal-container-{{ ai_gen_id }} {
      width: 95%;
    }
  }
