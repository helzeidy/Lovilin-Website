{%- doc -%}
  Bundle / pack selector.
  Shows the current product plus the products listed in its
  custom.bundle_products metafield as selectable cards (styled like the variant
  picker). Selecting a card and pressing "Add to cart" adds that product's
  variant to the cart. Bundle products stay hidden elsewhere on the site.
{%- enddoc -%}

{%- liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign ns = block.settings.metafield_namespace | default: 'custom'
  assign key = block.settings.metafield_key | default: 'bundle_products'
  assign bundles = product.metafields[ns][key].value
  assign uid = block.id | replace: '_', '' | downcase
-%}

{%- if product != blank -%}
  <script src="{{ 'product-form.js' | asset_url }}" type="module" fetchpriority="low"></script>

  <div class="bundle-selector" data-bundle-selector="{{ uid }}" {{ block.shopify_attributes }}>
    {%- if block.settings.heading != blank -%}
      <span class="bundle-selector__heading {{ block.settings.heading_preset | default: 'h6' }}">{{ block.settings.heading }}</span>
    {%- endif -%}

    <product-form-component id="BundleForm-{{ uid }}" class="bundle-selector__form-wrap">
      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="" ref="variantId" data-bundle-variant-input>

        <div class="bundle-selector__options">
          {%- liquid
            assign base_variant = product.selected_or_first_available_variant
          -%}
          {%- comment -%} Base product (e.g. 1 pack) {%- endcomment -%}
          <label class="bundle-option">
            <input
              type="radio"
              name="bundle-{{ uid }}"
              value="{{ base_variant.id }}"
              class="bundle-option__input"
              checked
            >
            <span class="bundle-option__body">
              <span class="bundle-option__label">{{ block.settings.base_label | default: product.title }}</span>
              {%- if block.settings.base_sublabel != blank -%}
                <span class="bundle-option__sublabel">{{ block.settings.base_sublabel }}</span>
              {%- endif -%}
              {%- if block.settings.show_price -%}
                <span class="bundle-option__price">{{ base_variant.price | money }}</span>
              {%- endif -%}
            </span>
          </label>

          {%- comment -%} Bundle products {%- endcomment -%}
          {%- if bundles != blank -%}
            {%- for bundle in bundles -%}
              {%- liquid
                assign b_variant = bundle.selected_or_first_available_variant
                assign b_label = bundle.metafields.custom.pack_label | default: bundle.title
                assign b_sub = bundle.metafields.custom.pack_sublabel
              -%}
              {%- if b_variant != blank -%}
                <label class="bundle-option{% unless b_variant.available %} bundle-option--soldout{% endunless %}">
                  <input
                    type="radio"
                    name="bundle-{{ uid }}"
                    value="{{ b_variant.id }}"
                    class="bundle-option__input"
                    {% unless b_variant.available %}disabled{% endunless %}
                  >
                  <span class="bundle-option__body">
                    <span class="bundle-option__label">{{ b_label }}</span>
                    {%- if b_sub != blank -%}
                      <span class="bundle-option__sublabel">{{ b_sub }}</span>
                    {%- endif -%}
                    {%- if block.settings.show_price -%}
                      <span class="bundle-option__price">{{ b_variant.price | money }}</span>
                    {%- endif -%}
                  </span>
                </label>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>

        {%- if block.settings.show_button -%}
          <add-to-cart-component class="bundle-selector__atc">
            <button type="submit" ref="addToCartButton" class="button bundle-selector__button">
              {{ block.settings.add_to_cart_text | default: 'Add to cart' }}
            </button>
          </add-to-cart-component>
        {%- endif -%}

        <div ref="liveRegion" class="visually-hidden" role="status"></div>
      </form>
    </product-form-component>
  </div>

  {%- style -%}
    .bundle-selector {
      display: block;
      width: 100%;
    }
    .bundle-selector__heading {
      display: block;
      margin-bottom: 10px;
    }
    .bundle-selector__options {
      display: grid;
      grid-template-columns: repeat({{ block.settings.columns | default: 2 }}, minmax(0, 1fr));
      gap: {{ block.settings.gap | default: 12 }}px;
    }
    .bundle-option {
      position: relative;
      display: block;
      cursor: pointer;
      border: {{ block.settings.border_width | default: 1 }}px solid {{ block.settings.border_color | default: '#e0e0e0' }};
      border-radius: {{ block.settings.card_radius | default: 12 }}px;
      background: {{ block.settings.card_bg | default: '#ffffff' }};
      padding: {{ block.settings.card_padding | default: 16 }}px;
      transition: border-color .15s ease, background-color .15s ease;
    }
    .bundle-option__input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .bundle-option:has(.bundle-option__input:checked) {
      border-color: {{ block.settings.selected_border_color | default: '#1a1a6e' }};
      background: {{ block.settings.selected_bg | default: '#eeeefb' }};
    }
    .bundle-option__body {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .bundle-option__label {
      font-weight: 600;
      color: {{ block.settings.label_color | default: '#1a1a6e' }};
    }
    .bundle-option__sublabel {
      font-size: var(--font-size--xs, 0.8125rem);
      opacity: 0.7;
    }
    .bundle-option__price {
      font-weight: 600;
      color: {{ block.settings.price_color | default: '#1a1a6e' }};
    }
    .bundle-option--soldout {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .bundle-selector__button {
      width: 100%;
      margin-top: {{ block.settings.button_gap | default: 16 }}px;
      justify-content: center;
    }
  {%- endstyle -%}

  <script>
    (function () {
      var root = document.querySelector('[data-bundle-selector="{{ uid }}"]');
      if (!root) return;
      var hidden = root.querySelector('[data-bundle-variant-input]');
      var radios = root.querySelectorAll('.bundle-option__input');
      function sync() {
        radios.forEach(function (r) { if (r.checked) hidden.value = r.value; });
      }
      radios.forEach(function (r) { r.addEventListener('change', sync); });
      sync();
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Bundle selector",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows this product plus the products in its custom.bundle_products metafield as selectable packs. Add a 'custom.bundle_products' product-list metafield to the main product, and optionally 'custom.pack_label' text metafields on each bundle product."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your pack"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Heading size",
      "options": [
        { "value": "h4", "label": "H4" },
        { "value": "h5", "label": "H5" },
        { "value": "h6", "label": "H6" },
        { "value": "paragraph", "label": "Paragraph" }
      ],
      "default": "h6"
    },
    {
      "type": "text",
      "id": "base_label",
      "label": "Base product label",
      "info": "Label for this product (e.g. \"1 Bottle\").",
      "default": "1 Bottle"
    },
    {
      "type": "text",
      "id": "base_sublabel",
      "label": "Base product sub-label"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price on cards",
      "default": true
    },
    {
      "type": "header",
      "content": "Add to cart"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show add-to-cart button",
      "default": true
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
      "label": "Button text",
      "default": "Add to cart"
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Space above button",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 4,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Card border width",
      "min": 0,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Card border",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "selected_bg",
      "label": "Selected background",
      "default": "#eeeefb"
    },
    {
      "type": "color",
      "id": "selected_border_color",
      "label": "Selected border",
      "default": "#1a1a6e"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1a1a6e"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#1a1a6e"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "bundle_products"
    }
  ],
  "presets": [
    {
      "name": "Bundle selector",
      "category": "Product"
    }
  ]
}
{% endschema %}
