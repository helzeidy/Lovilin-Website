{% doc %}
  @prompt
    Create a custom banner block for the collection product grid that:
    - Injects a banner card directly inside the product grid, appearing at a configurable position (e.g., after the 2nd or 4th product card)
    - Automatically matches the exact height of the adjacent product cards using CSS grid or flexbox
    - Supports a customizable background image (uploaded via theme editor)
    - Includes overlay content: heading, subheading, and a CTA button (all editable in theme editor)
    - Overlay text and button colors are customizable via theme editor settings
    - The banner occupies one grid cell (same width as a product card) and stretches to match the card height
    - Works responsively — stacks naturally on mobile with the product cards
    - The position in the grid (after which product card number) is configurable in theme editor settings
    - No gap or misalignment with surrounding product cards
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-grid-banner-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 300px;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-grid-banner-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-grid-banner-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-grid-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-grid-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-grid-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.vertical_alignment }};
    align-items: {{ block.settings.horizontal_alignment }};
    height: 100%;
    padding: {{ block.settings.content_padding }}px;
    text-align: {% if block.settings.horizontal_alignment == 'flex-start' %}left{% elsif block.settings.horizontal_alignment == 'flex-end' %}right{% else %}center{% endif %};
  }

  .ai-grid-banner-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-grid-banner-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 {{ block.settings.button_spacing }}px 0;
    line-height: 1.4;
  }

  .ai-grid-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-grid-banner-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-grid-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 8px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    z-index: 3;
  }

  @media screen and (max-width: 749px) {
    .ai-grid-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-grid-banner-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
    }

    .ai-grid-banner-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<grid-banner-{{ ai_gen_id }}
  class="ai-grid-banner-{{ ai_gen_id }}"
  data-position="{{ block.settings.grid_position }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.banner_image %}
    <img
      src="{{ block.settings.banner_image | image_url: width: 800 }}"
      alt="{{ block.settings.banner_image.alt | escape }}"
      loading="lazy"
      width="{{ block.settings.banner_image.width }}"
      height="{{ block.settings.banner_image.height }}"
      class="ai-grid-banner-image-{{ ai_gen_id }}"
    >
  {% else %}
    <div class="ai-grid-banner-placeholder-{{ ai_gen_id }}">
      {{ 'collection-1' | placeholder_svg_tag }}
    </div>
  {% endif %}

  <div class="ai-grid-banner-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-grid-banner-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h3 class="ai-grid-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-grid-banner-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}

    {% if block.settings.button_text != blank and block.settings.button_link != blank %}
      <a
        href="{{ block.settings.button_link }}"
        class="ai-grid-banner-button-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>

  {% if block.settings.banner_image == blank %}
    <div class="ai-grid-banner-empty-state-{{ ai_gen_id }}">
      Add a background image to get started
    </div>
  {% endif %}
</grid-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class GridBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.position = parseInt(this.dataset.position) || 2;
      }

      connectedCallback() {
        this.insertIntoGrid();
      }

      insertIntoGrid() {
        const productGrid = this.closest('.collection, .product-grid, [class*="grid"]');
        if (!productGrid) return;

        const productCards = Array.from(productGrid.children).filter(child => {
          return child.tagName.toLowerCase().includes('product') || 
                 child.classList.toString().includes('product') ||
                 child.classList.toString().includes('card');
        });

        if (productCards.length >= this.position) {
          const targetCard = productCards[this.position - 1];
          if (targetCard && targetCard.nextSibling) {
            targetCard.parentNode.insertBefore(this, targetCard.nextSibling);
          } else if (targetCard) {
            targetCard.parentNode.appendChild(this);
          }
        }
      }
    }

    customElements.define('grid-banner-{{ ai_gen_id }}', GridBanner{{ ai_gen_id }});
  })();
</script>

