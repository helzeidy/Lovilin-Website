{% doc %}
  @prompt
    "Create a custom product collection text color block that: 1) Reads the current product's collections, 2) Allows merchants to map collection handles to specific text colors via theme editor settings (support at least 5 collection-to-color pairs), 3) Applies the matched color to a configurable text element (product title, badge, or description), 4) Falls back to a default color if no collection match is found, 5) Supports text case transformation (uppercase option), 6) Is responsive with separate width controls for desktop and mobile, 7) Includes padding controls for top, bottom, left, and right on both desktop and mobile, 8) Works on both desktop and mobile views with proper fit and fill for text."
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign matched_color = block.settings.default_color
  assign collection_handle_1 = block.settings.collection_handle_1
  assign collection_handle_2 = block.settings.collection_handle_2
  assign collection_handle_3 = block.settings.collection_handle_3
  assign collection_handle_4 = block.settings.collection_handle_4
  assign collection_handle_5 = block.settings.collection_handle_5

  for collection in product.collections
    if collection.handle == collection_handle_1 and collection_handle_1 != blank
      assign matched_color = block.settings.collection_color_1
      break
    elsif collection.handle == collection_handle_2 and collection_handle_2 != blank
      assign matched_color = block.settings.collection_color_2
      break
    elsif collection.handle == collection_handle_3 and collection_handle_3 != blank
      assign matched_color = block.settings.collection_color_3
      break
    elsif collection.handle == collection_handle_4 and collection_handle_4 != blank
      assign matched_color = block.settings.collection_color_4
      break
    elsif collection.handle == collection_handle_5 and collection_handle_5 != blank
      assign matched_color = block.settings.collection_color_5
      break
    endif
  endfor
%}

{% style %}
  .ai-collection-text-color-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-collection-text-color-content-{{ ai_gen_id }} {
    color: {{ matched_color }};
    {% if block.settings.text_transform_uppercase %}
      text-transform: uppercase;
    {% endif %}
    margin: 0;
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    padding-left: {{ block.settings.padding_left_desktop }}px;
    padding-right: {{ block.settings.padding_right_desktop }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-text-color-content-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
      padding-left: {{ block.settings.padding_left_mobile }}px;
      padding-right: {{ block.settings.padding_right_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-text-color-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.text_element == 'title' %}
    <h2 class="ai-collection-text-color-content-{{ ai_gen_id }}">{{ product.title }}</h2>
  {% elsif block.settings.text_element == 'badge' %}
    <span class="ai-collection-text-color-content-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
  {% elsif block.settings.text_element == 'description' %}
    <div class="ai-collection-text-color-content-{{ ai_gen_id }}">{{ product.description | strip_html | truncate: 200 }}</div>
  {% endif %}
</div>

