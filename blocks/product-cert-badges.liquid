{% comment %}
  Product certification / feature badges.
  Reads a list of "badge" metaobjects from a product metafield so each product
  shows its own icons + labels. Merchant uploads the icon image on the metaobject
  entry and references entries via the product metafield (default: custom.cert_badges).

  Expected metaobject fields (keys): icon (file/image), label (text), subtitle (text, optional)
{% endcomment %}

{% liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign namespace = block.settings.metafield_namespace | default: 'custom'
  assign key = block.settings.metafield_key | default: 'cert_badges'
  assign badges = product.metafields[namespace][key].value
%}

{% assign ai_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .cert-badges-{{ ai_id }} {
    display: flex;
    flex-wrap: wrap;
    justify-content: {{ block.settings.alignment }};
    align-items: flex-start;
    gap: {{ block.settings.gap }}px;
    width: 100%;
    padding-top: {{ block.settings.padding_block_start }}px;
    padding-bottom: {{ block.settings.padding_block_end }}px;
    padding-left: {{ block.settings.padding_inline_start }}px;
    padding-right: {{ block.settings.padding_inline_end }}px;
    {% if block.settings.background != blank %}background-color: {{ block.settings.background }};{% endif %}
    {% if block.settings.background != blank %}border-radius: {{ block.settings.background_radius }}px;{% endif %}
  }

  .cert-badge-{{ ai_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: {{ block.settings.circle_size | plus: 16 }}px;
    gap: 8px;
  }

  .cert-badge__circle-{{ ai_id }} {
    width: {{ block.settings.circle_size }}px;
    height: {{ block.settings.circle_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.show_ring %}border: {{ block.settings.ring_width }}px solid {{ block.settings.ring_color }};{% endif %}
    {% if block.settings.circle_background != blank %}background-color: {{ block.settings.circle_background }};{% endif %}
    overflow: hidden;
    flex: 0 0 auto;
  }

  .cert-badge__circle-{{ ai_id }} img,
  .cert-badge__circle-{{ ai_id }} svg {
    width: {{ block.settings.icon_size }}%;
    height: {{ block.settings.icon_size }}%;
    object-fit: contain;
  }

  .cert-badge__label-{{ ai_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    line-height: 1.15;
    letter-spacing: 0.04em;
    color: {{ block.settings.label_color }};
    {% if block.settings.uppercase %}text-transform: uppercase;{% endif %}
  }

  .cert-badge__subtitle-{{ ai_id }} {
    font-size: {{ block.settings.label_size | minus: 2 }}px;
    color: {{ block.settings.label_color }};
    opacity: 0.7;
    line-height: 1.15;
  }

  @media screen and (max-width: 749px) {
    .cert-badges-{{ ai_id }} {
      gap: {{ block.settings.gap_mobile }}px;
    }
    .cert-badge-{{ ai_id }} {
      width: {{ block.settings.circle_size_mobile | plus: 12 }}px;
    }
    .cert-badge__circle-{{ ai_id }} {
      width: {{ block.settings.circle_size_mobile }}px;
      height: {{ block.settings.circle_size_mobile }}px;
    }
  }
{% endstyle %}

{% if badges != blank %}
  <div class="cert-badges-{{ ai_id }}" {{ block.shopify_attributes }}>
    {% for badge in badges %}
      {%- liquid
        assign icon_img = badge.icon.value | default: badge.icon
        assign label = badge.label.value | default: badge.label
        assign subtitle = badge.subtitle.value | default: badge.subtitle
      -%}
      <div class="cert-badge-{{ ai_id }}">
        <div class="cert-badge__circle-{{ ai_id }}">
          {% if icon_img != blank %}
            <img
              src="{{ icon_img | image_url: width: 240 }}"
              alt="{{ label | escape }}"
              width="240"
              height="240"
              loading="lazy"
            >
          {% endif %}
        </div>
        {% if label != blank %}
          <span class="cert-badge__label-{{ ai_id }}">{{ label }}</span>
        {% endif %}
        {% if subtitle != blank %}
          <span class="cert-badge__subtitle-{{ ai_id }}">{{ subtitle }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
{% elsif request.design_mode %}
  <div class="cert-badges-{{ ai_id }}" {{ block.shopify_attributes }}>
    <p style="opacity:.6;font-size:13px;">
      No badges found. Add metaobject entries to the product metafield
      <strong>{{ namespace }}.{{ key }}</strong>.
    </p>
  </div>
{% endif %}

{% schema %}
{
  "name": "Certification badges",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Data source"
    },
    {
      "type": "paragraph",
      "content": "Reads a list of badge metaobjects from a product metafield. Each badge metaobject needs an icon (image), a label, and an optional subtitle."
    },
    {
      "type": "text",
      "id": "metafield_namespace",
      "label": "Metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "metafield_key",
      "label": "Metafield key",
      "default": "cert_badges"
    },
    {
      "type": "header",
      "content": "Circle"
    },
    {
      "type": "range",
      "id": "circle_size",
      "label": "Circle size (desktop)",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 84
    },
    {
      "type": "range",
      "id": "circle_size_mobile",
      "label": "Circle size (mobile)",
      "min": 32,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size inside circle",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "show_ring",
      "label": "Show ring border",
      "default": false
    },
    {
      "type": "range",
      "id": "ring_width",
      "label": "Ring width",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "ring_color",
      "label": "Ring color",
      "default": "#1a1a6e"
    },
    {
      "type": "color",
      "id": "circle_background",
      "label": "Circle background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Label"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "label_weight",
      "label": "Label weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase label",
      "default": true
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#1a1a6e"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "space-between", "label": "Space between" }
      ],
      "default": "space-between"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap (desktop)",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap (mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "color",
      "id": "background",
      "label": "Strip background",
      "default": ""
    },
    {
      "type": "range",
      "id": "background_radius",
      "label": "Strip background radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_inline_start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_inline_end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Certification badges",
      "category": "Product"
    }
  ]
}
{% endschema %}

{% comment %} v1 {% endcomment %}
