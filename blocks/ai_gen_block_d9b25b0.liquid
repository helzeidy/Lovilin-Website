{% doc %}
  @prompt
    Create a highly configurable horizontal product card block with the following requirements:
    
    VISIBILITY TOGGLES (show/hide each element independently):
    - Product image
    - Product title
    - Price (regular and compare-at)
    - Badge / label
    - Product description / excerpt
    - Vendor name
    - SKU
    - Star rating placeholder
    - Add-to-cart button
    - Wishlist button
    - Quick view button
    - Divider line between image and content
    
    CUSTOM TEXT & CONTENT FIELDS:
    - Custom badge text (free text input)
    - Custom label / tag text
    - Custom button label text
    - Custom card heading or eyebrow text above the title
    - Custom footer note text below the button
    
    LAYOUT & SIZING OPTIONS (numeric inputs):
    - Image width percentage (e.g. 30–60%)
    - Card border radius (px)
    - Gap between image and content (px)
    - Button border radius (px)
    - Badge border radius (px)
    - Min card height (px)
    - Max card width (px)
    
    MOBILE OPTIONS:
    - Toggle to stack vertically on mobile
    - Mobile image position (top or bottom when stacked)
    - Mobile image height (px)
    - Mobile padding (px)
    - Hide specific elements on mobile (image, badge, description, vendor, SKU)
    
    COLOR & STYLE OPTIONS:
    - Card background color
    - Card border color and width
    - Title color
    - Price color
    - Badge background and text color
    - Button background and text color
    - Hover state color for button
    - Text content area background color
    
    Match a premium dark aesthetic with clean typography. All settings should be editable from the Shopify theme editor sidebar.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  case block.settings.title_type
    when 'h1'
      assign title_size_desktop = '2.5rem'
      assign title_size_mobile = '2rem'
    when 'h2'
      assign title_size_desktop = '2rem'
      assign title_size_mobile = '1.625rem'
    when 'h3'
      assign title_size_desktop = '1.5rem'
      assign title_size_mobile = '1.25rem'
    when 'h4'
      assign title_size_desktop = '1.25rem'
      assign title_size_mobile = '1.125rem'
    when 'paragraph'
      assign title_size_desktop = '1rem'
      assign title_size_mobile = '1rem'
    when 'small'
      assign title_size_desktop = '0.875rem'
      assign title_size_mobile = '0.875rem'
  endcase

  case block.settings.description_type
    when 'h1'
      assign desc_size_desktop = '2.5rem'
      assign desc_size_mobile = '2rem'
    when 'h2'
      assign desc_size_desktop = '2rem'
      assign desc_size_mobile = '1.625rem'
    when 'h3'
      assign desc_size_desktop = '1.5rem'
      assign desc_size_mobile = '1.25rem'
    when 'h4'
      assign desc_size_desktop = '1.25rem'
      assign desc_size_mobile = '1.125rem'
    when 'paragraph'
      assign desc_size_desktop = '1rem'
      assign desc_size_mobile = '1rem'
    when 'small'
      assign desc_size_desktop = '0.875rem'
      assign desc_size_mobile = '0.875rem'
  endcase

  case block.settings.eyebrow_type
    when 'h1'
      assign eyebrow_size_desktop = '2.5rem'
      assign eyebrow_size_mobile = '2rem'
    when 'h2'
      assign eyebrow_size_desktop = '2rem'
      assign eyebrow_size_mobile = '1.625rem'
    when 'h3'
      assign eyebrow_size_desktop = '1.5rem'
      assign eyebrow_size_mobile = '1.25rem'
    when 'h4'
      assign eyebrow_size_desktop = '1.25rem'
      assign eyebrow_size_mobile = '1.125rem'
    when 'paragraph'
      assign eyebrow_size_desktop = '1rem'
      assign eyebrow_size_mobile = '1rem'
    when 'small'
      assign eyebrow_size_desktop = '0.875rem'
      assign eyebrow_size_mobile = '0.875rem'
  endcase

  case block.settings.footer_note_type
    when 'h1'
      assign note_size_desktop = '2.5rem'
      assign note_size_mobile = '2rem'
    when 'h2'
      assign note_size_desktop = '2rem'
      assign note_size_mobile = '1.625rem'
    when 'h3'
      assign note_size_desktop = '1.5rem'
      assign note_size_mobile = '1.25rem'
    when 'h4'
      assign note_size_desktop = '1.25rem'
      assign note_size_mobile = '1.125rem'
    when 'paragraph'
      assign note_size_desktop = '1rem'
      assign note_size_mobile = '1rem'
    when 'small'
      assign note_size_desktop = '0.875rem'
      assign note_size_mobile = '0.875rem'
  endcase

  case block.settings.price_type
    when 'h1'
      assign price_size_desktop = '2.5rem'
      assign price_size_mobile = '2rem'
    when 'h2'
      assign price_size_desktop = '2rem'
      assign price_size_mobile = '1.625rem'
    when 'h3'
      assign price_size_desktop = '1.5rem'
      assign price_size_mobile = '1.25rem'
    when 'h4'
      assign price_size_desktop = '1.25rem'
      assign price_size_mobile = '1.125rem'
    when 'paragraph'
      assign price_size_desktop = '1rem'
      assign price_size_mobile = '1rem'
    when 'small'
      assign price_size_desktop = '0.875rem'
      assign price_size_mobile = '0.875rem'
  endcase
-%}

{% style %}
  .ai-horizontal-card-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-horizontal-card__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    background-color: {{ block.settings.card_bg_color }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 0;
    gap: {{ block.settings.content_gap }}px;
    min-height: {{ block.settings.min_card_height }}px;
    max-width: {{ block.settings.max_card_width }}px;
    width: 100%;
    overflow: hidden;
  }

  .ai-horizontal-card__image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.image_width_percent }}%;
    position: relative;
    overflow: hidden;
  }

  .ai-horizontal-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .ai-horizontal-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    z-index: 2;
  }

  .ai-horizontal-card__content-wrapper-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background-color: {{ block.settings.content_bg_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-right: {{ block.settings.padding_right }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
  }

  /* Eyebrow */
  .ai-horizontal-card__eyebrow-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: {{ eyebrow_size_desktop }};
    color: {{ block.settings.title_color }};
    opacity: 0.7;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Title */
  .ai-horizontal-card__title-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: {{ title_size_desktop }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  /* Vendor */
  .ai-horizontal-card__vendor-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    font-size: {{ desc_size_desktop }};
    color: {{ block.settings.title_color }};
    opacity: 0.6;
    margin: 0;
  }

  /* Price */
  .ai-horizontal-card__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-horizontal-card__price-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight-bold, 700);
    font-size: {{ price_size_desktop }};
    color: {{ block.settings.price_color }};
  }

  .ai-horizontal-card__compare-price-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ price_size_desktop }};
    color: {{ block.settings.price_color }};
    opacity: 0.5;
    text-decoration: line-through;
  }

  /* Description */
  .ai-horizontal-card__description-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    font-size: {{ desc_size_desktop }};
    line-height: 1.6;
    color: {{ block.settings.title_color }};
    opacity: 0.8;
    margin: 0;
  }

  /* SKU */
  .ai-horizontal-card__sku-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    color: {{ block.settings.title_color }};
    opacity: 0.5;
  }

  /* Rating */
  .ai-horizontal-card__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-body-family);
    font-size: {{ desc_size_desktop }};
    color: {{ block.settings.badge_bg_color }};
  }

  /* Divider */
  .ai-horizontal-card__divider-{{ ai_gen_id }} {
    width: 1px;
    background-color: {{ block.settings.card_border_color }};
    align-self: stretch;
  }

  /* Buttons */
  .ai-horizontal-card__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-top: auto;
  }

  .ai-horizontal-card__button-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight-bold, 600);
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: inline-block;
  }

  .ai-horizontal-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-horizontal-card__button--secondary-{{ ai_gen_id }} {
    background-color: transparent;
    border: 1px solid {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_bg_color }};
  }

  .ai-horizontal-card__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
  }

  /* Footer note */
  .ai-horizontal-card__footer-note-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ note_size_desktop }};
    color: {{ block.settings.title_color }};
    opacity: 0.6;
    margin: 0;
    font-style: italic;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    .ai-horizontal-card__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_stack %}
        flex-direction: column;
      {% endif %}
      padding: 0;
    }

    .ai-horizontal-card__eyebrow-{{ ai_gen_id }} {
      font-size: {{ eyebrow_size_mobile }};
    }

    .ai-horizontal-card__title-{{ ai_gen_id }} {
      font-size: {{ title_size_mobile }};
    }

    .ai-horizontal-card__vendor-{{ ai_gen_id }},
    .ai-horizontal-card__description-{{ ai_gen_id }},
    .ai-horizontal-card__rating-{{ ai_gen_id }} {
      font-size: {{ desc_size_mobile }};
    }

    .ai-horizontal-card__price-{{ ai_gen_id }},
    .ai-horizontal-card__compare-price-{{ ai_gen_id }} {
      font-size: {{ price_size_mobile }};
    }

    .ai-horizontal-card__footer-note-{{ ai_gen_id }} {
      font-size: {{ note_size_mobile }};
    }

    {% if block.settings.mobile_stack %}
      .ai-horizontal-card__image-wrapper-{{ ai_gen_id }} {
        width: 100%;
        height: {{ block.settings.mobile_image_height }}px;
        {% if block.settings.mobile_image_position == 'bottom' %}
          order: 2;
        {% endif %}
      }

      .ai-horizontal-card__content-wrapper-{{ ai_gen_id }} {
        padding: {{ block.settings.mobile_padding }}px;
        {% if block.settings.mobile_image_position == 'bottom' %}
          order: 1;
        {% endif %}
      }

      .ai-horizontal-card__divider-{{ ai_gen_id }} {
        width: 100%;
        height: 1px;
      }
    {% endif %}

    {% if block.settings.mobile_hide_image %}
      .ai-horizontal-card__image-wrapper-{{ ai_gen_id }} { display: none; }
    {% endif %}

    {% if block.settings.mobile_hide_badge %}
      .ai-horizontal-card__badge-{{ ai_gen_id }} { display: none; }
    {% endif %}

    {% if block.settings.mobile_hide_description %}
      .ai-horizontal-card__description-{{ ai_gen_id }} { display: none; }
    {% endif %}

    {% if block.settings.mobile_hide_vendor %}
      .ai-horizontal-card__vendor-{{ ai_gen_id }} { display: none; }
    {% endif %}

    {% if block.settings.mobile_hide_sku %}
      .ai-horizontal-card__sku-{{ ai_gen_id }} { display: none; }
    {% endif %}
  }
{% endstyle %}

<horizontal-product-card-{{ ai_gen_id }} class="ai-horizontal-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-horizontal-card__container-{{ ai_gen_id }}">
    {% if block.settings.show_image %}
      <div class="ai-horizontal-card__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product %}
          {% if block.settings.product.featured_image %}
            <img
              src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
              alt="{{ block.settings.product.featured_image.alt | escape }}"
              class="ai-horizontal-card__image-{{ ai_gen_id }}"
              loading="lazy"
              width="800"
              height="800"
            >
          {% else %}
            <div class="ai-horizontal-card__image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        {% else %}
          <div class="ai-horizontal-card__image-{{ ai_gen_id }}" style="background-color: #f4f4f4; display: flex; align-items: center; justify-content: center;">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.show_badge and block.settings.badge_text != blank %}
          <div class="ai-horizontal-card__badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-horizontal-card__divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-horizontal-card__content-wrapper-{{ ai_gen_id }}">
      {% if block.settings.show_eyebrow and block.settings.eyebrow_text != blank %}
        <p class="ai-horizontal-card__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow_text }}</p>
      {% endif %}

      {% if block.settings.show_title %}
        <h3 class="ai-horizontal-card__title-{{ ai_gen_id }}">
          {% if block.settings.product %}
            {{ block.settings.product.title }}
          {% else %}
            Premium Product Title
          {% endif %}
        </h3>
      {% endif %}

      {% if block.settings.show_vendor %}
        <p class="ai-horizontal-card__vendor-{{ ai_gen_id }}">
          {% if block.settings.product %}
            {{ block.settings.product.vendor }}
          {% else %}
            Brand Name
          {% endif %}
        </p>
      {% endif %}

      {% if block.settings.show_price %}
        <div class="ai-horizontal-card__price-wrapper-{{ ai_gen_id }}">
          <span class="ai-horizontal-card__price-{{ ai_gen_id }}">
            {% if block.settings.product %}
              {{ block.settings.product.price | money }}
            {% else %}
              EGP 299.00
            {% endif %}
          </span>
          {% if block.settings.product and block.settings.product.compare_at_price > block.settings.product.price %}
            <span class="ai-horizontal-card__compare-price-{{ ai_gen_id }}">
              {{ block.settings.product.compare_at_price | money }}
            </span>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.show_rating %}
        <div class="ai-horizontal-card__rating-{{ ai_gen_id }}">
          <span>★★★★★</span>
          <span style="opacity: 0.6;">(4.8)</span>
        </div>
      {% endif %}

      {% if block.settings.show_description %}
        <p class="ai-horizontal-card__description-{{ ai_gen_id }}">
          {% if block.settings.product and block.settings.product.description != blank %}
            {{ block.settings.product.description | strip_html | truncate: 150 }}
          {% else %}
            Experience premium quality with this carefully crafted product designed for modern living.
          {% endif %}
        </p>
      {% endif %}

      {% if block.settings.show_sku %}
        <div class="ai-horizontal-card__sku-{{ ai_gen_id }}">
          SKU:
          {% if block.settings.product and block.settings.product.selected_or_first_available_variant.sku != blank %}
            {{ block.settings.product.selected_or_first_available_variant.sku }}
          {% else %}
            PROD-12345
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-horizontal-card__buttons-{{ ai_gen_id }}">
        {% if block.settings.show_add_to_cart %}
          <a
            href="{% if block.settings.product %}{{ block.settings.product.url }}{% else %}#{% endif %}"
            class="ai-horizontal-card__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}

        {% if block.settings.show_wishlist %}
          <button class="ai-horizontal-card__button-{{ ai_gen_id }} ai-horizontal-card__button--secondary-{{ ai_gen_id }}">
            ♡
          </button>
        {% endif %}

        {% if block.settings.show_quick_view %}
          <button class="ai-horizontal-card__button-{{ ai_gen_id }} ai-horizontal-card__button--secondary-{{ ai_gen_id }}">
            Quick view
          </button>
        {% endif %}
      </div>

      {% if block.settings.show_footer_note and block.settings.footer_note_text != blank %}
        <p class="ai-horizontal-card__footer-note-{{ ai_gen_id }}">{{ block.settings.footer_note_text }}</p>
      {% endif %}
    </div>
  </div>
</horizontal-product-card-{{ ai_gen_id }}>

<script>
  (function() {
    class HorizontalProductCard{{ ai_gen_id }} extends HTMLElement {
      constructor() { super(); }
      connectedCallback() {}
    }
    customElements.define('horizontal-product-card-{{ ai_gen_id }}', HorizontalProductCard{{ ai_gen_id }});
  })();
</script>

