{% doc %}
  @prompt
    guaranteed safe checkout widget with visa mastercard and meeza , give me an option to input the icons 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-safe-checkout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-safe-checkout__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
  }

  .ai-safe-checkout__icons-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-safe-checkout__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: auto;
    opacity: {{ block.settings.icon_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
  }

  .ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-safe-checkout__icon-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-safe-checkout__icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.icon_size | times: 0.66 }}px;
    background-color: #e0e0e0;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #999;
  }

  @media screen and (max-width: 749px) {
    .ai-safe-checkout-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-safe-checkout__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-safe-checkout__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-safe-checkout__icon-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.icon_size | times: 0.53 }}px;
    }
  }
{% endstyle %}

<div class="ai-safe-checkout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <div class="ai-safe-checkout__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </div>
  {% endif %}

  <div class="ai-safe-checkout__icons-{{ ai_gen_id }}">
    {% if block.settings.show_icon_1 %}
      <div class="ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}">
        {% if block.settings.icon_1 != blank %}
          <img
            src="{{ block.settings.icon_1 | image_url: width: 200 }}"
            alt="{{ block.settings.icon_1_alt | escape }}"
            loading="lazy"
            width="200"
            height="auto"
          >
        {% else %}
          <div class="ai-safe-checkout__icon-placeholder-{{ ai_gen_id }}">Icon 1</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_icon_2 %}
      <div class="ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}">
        {% if block.settings.icon_2 != blank %}
          <img
            src="{{ block.settings.icon_2 | image_url: width: 200 }}"
            alt="{{ block.settings.icon_2_alt | escape }}"
            loading="lazy"
            width="200"
            height="auto"
          >
        {% else %}
          <div class="ai-safe-checkout__icon-placeholder-{{ ai_gen_id }}">Icon 2</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_icon_3 %}
      <div class="ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}">
        {% if block.settings.icon_3 != blank %}
          <img
            src="{{ block.settings.icon_3 | image_url: width: 200 }}"
            alt="{{ block.settings.icon_3_alt | escape }}"
            loading="lazy"
            width="200"
            height="auto"
          >
        {% else %}
          <div class="ai-safe-checkout__icon-placeholder-{{ ai_gen_id }}">Icon 3</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_icon_4 %}
      <div class="ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}">
        {% if block.settings.icon_4 != blank %}
          <img
            src="{{ block.settings.icon_4 | image_url: width: 200 }}"
            alt="{{ block.settings.icon_4_alt | escape }}"
            loading="lazy"
            width="200"
            height="auto"
          >
        {% else %}
          <div class="ai-safe-checkout__icon-placeholder-{{ ai_gen_id }}">Icon 4</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_icon_5 %}
      <div class="ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}">
        {% if block.settings.icon_5 != blank %}
          <img
            src="{{ block.settings.icon_5 | image_url: width: 200 }}"
            alt="{{ block.settings.icon_5_alt | escape }}"
            loading="lazy"
            width="200"
            height="auto"
          >
        {% else %}
          <div class="ai-safe-checkout__icon-placeholder-{{ ai_gen_id }}">Icon 5</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_icon_6 %}
      <div class="ai-safe-checkout__icon-wrapper-{{ ai_gen_id }}">
        {% if block.settings.icon_6 != blank %}
          <img
            src="{{ block.settings.icon_6 | image_url: width: 200 }}"
            alt="{{ block.settings.icon_6_alt | escape }}"
            loading="lazy"
            width="200"
            height="auto"
          >
        {% else %}
          <div class="ai-safe-checkout__icon-placeholder-{{ ai_gen_id }}">Icon 6</div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

