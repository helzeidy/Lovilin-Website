{% doc %}
  @prompt
    Edit the existing "Horizontal product card" AI-generated block to add the following schema settings:
    1. A text size setting for desktop (range input, labeled "Desktop text size", in px)
    2. A separate text size setting for mobile (range input, labeled "Mobile text size", in px), applied via CSS media query for screens below 768px
    3. Four separate padding settings: padding-top, padding-right, padding-bottom, padding-left (each a range input in px, labeled accordingly)
    Apply all settings using a scoped style tag with a unique block ID.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  assign bg_color = block.settings.background_color
  assign title_color = block.settings.title_color
  assign description_color = block.settings.description_color
  assign price_color = block.settings.price_color
  assign button_background = block.settings.button_background
  assign button_text_color = block.settings.button_text_color
  assign button_hover_background = block.settings.button_hover_background
  assign button_hover_text_color = block.settings.button_hover_text_color

  if block.settings.use_theme_colors
    assign bg_color = 'var(--color-background)'
    assign title_color = 'var(--color-foreground)'
    assign description_color = 'var(--color-foreground)'
    assign price_color = 'var(--color-foreground)'
    assign button_background = 'var(--color-primary, var(--color-foreground))'
    assign button_text_color = 'var(--color-background)'
    assign button_hover_background = 'var(--color-foreground)'
    assign button_hover_text_color = 'var(--color-background)'
  endif
-%}

{% style %}
  .ai-horizontal-product-card-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-right: {{ block.settings.padding_right }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
  }

  .ai-horizontal-product-card__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    background-color: {{ bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    height: 100%;
  }

  .ai-horizontal-product-card__image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: relative;
    overflow: hidden;
    {% if block.settings.image_aspect_ratio != 'original' %}
      aspect-ratio: {{ block.settings.image_aspect_ratio }};
      align-self: flex-start;
      height: auto;
    {% endif %}
  }

  .ai-horizontal-product-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    object-position: center;
  }

  .ai-horizontal-product-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-horizontal-product-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-horizontal-product-card__content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-horizontal-product-card__title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font }};
    font-size: {{ block.settings.desktop_text_size }}px;
    color: {{ title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-horizontal-product-card__description-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ description_color }};
    margin: 0 0 {{ block.settings.description_margin }}px;
    line-height: 1.5;
  }

  .ai-horizontal-product-card__price-{{ ai_gen_id }} {
    font-family: {{ block.settings.body_font }};
    font-size: {{ block.settings.price_size }}px;
    color: {{ price_color }};
    font-weight: {{ block.settings.price_weight }};
    margin: 0 0 {{ block.settings.price_margin }}px;
  }

  .ai-horizontal-product-card__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ button_background }};
    color: {{ button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-align: center;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.button_text_size }}px;
  }

  .ai-horizontal-product-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ button_hover_background }};
    color: {{ button_hover_text_color }};
  }

  @media screen and (max-width: 767px) {
    .ai-horizontal-product-card__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-horizontal-product-card__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-horizontal-product-card__image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 auto;
      height: 200px;
    }
  }
{% endstyle %}

<div class="ai-horizontal-product-card-{{ ai_gen_id }}{% if block.settings.use_theme_colors %} color-{{ block.settings.color_scheme }}{% endif %}" {{ block.shopify_attributes }}>
  <div class="ai-horizontal-product-card__container-{{ ai_gen_id }}">
    <div class="ai-horizontal-product-card__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product %}
        {% if block.settings.product.featured_image %}
          <img
            src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
            alt="{{ block.settings.product.featured_image.alt | escape }}"
            class="ai-horizontal-product-card__image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product.featured_image.width }}"
            height="{{ block.settings.product.featured_image.height }}"
          >
        {% else %}
          <div class="ai-horizontal-product-card__image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      {% else %}
        <div class="ai-horizontal-product-card__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-horizontal-product-card__content-{{ ai_gen_id }}">
      {% if block.settings.product %}
        <h3 class="ai-horizontal-product-card__title-{{ ai_gen_id }}">
          {{ block.settings.product.title }}
        </h3>

        {% if block.settings.show_description and block.settings.product.description != blank %}
          <div class="ai-horizontal-product-card__description-{{ ai_gen_id }}">
            {{ block.settings.product.description | strip_html | truncate: 120 }}
          </div>
        {% endif %}

        {% if block.settings.show_price %}
          <div class="ai-horizontal-product-card__price-{{ ai_gen_id }}">
            {{ block.settings.product.price | money }}
          </div>
        {% endif %}

        {% if block.settings.show_button %}
          <a
            href="{{ block.settings.product.url }}"
            class="ai-horizontal-product-card__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      {% else %}
        <h3 class="ai-horizontal-product-card__title-{{ ai_gen_id }}">
          Product title
        </h3>
        <div class="ai-horizontal-product-card__description-{{ ai_gen_id }}">
          Select a product to display in this horizontal card layout.
        </div>
        <div class="ai-horizontal-product-card__price-{{ ai_gen_id }}">
          EGP 0.00
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Horizontal product card",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View product"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "label": "Padding right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "label": "Padding left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between image and content",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image width",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "original", "label": "Fill card height" },
        { "value": "1 / 1", "label": "Square (1:1)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" },
        { "value": "16 / 9", "label": "Wide (16:9)" }
      ],
      "default": "1 / 1"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "info": "Fit shows the whole product centered. Fill crops the image to fill the container.",
      "options": [
        { "value": "contain", "label": "Fit (show whole product)" },
        { "value": "cover", "label": "Fill (crop to fill)" }
      ],
      "default": "contain"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Content padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Title font",
      "options": [
        { "value": "var(--font-heading--family)", "label": "Heading" },
        { "value": "var(--font-body--family)", "label": "Body" },
        { "value": "var(--font-subheading--family)", "label": "Subheading" },
        { "value": "var(--font-accent--family)", "label": "Accent" }
      ],
      "default": "var(--font-heading--family)"
    },
    {
      "type": "select",
      "id": "body_font",
      "label": "Text & price font",
      "options": [
        { "value": "var(--font-body--family)", "label": "Body" },
        { "value": "var(--font-subheading--family)", "label": "Subheading" },
        { "value": "var(--font-heading--family)", "label": "Heading" },
        { "value": "var(--font-accent--family)", "label": "Accent" }
      ],
      "default": "var(--font-body--family)"
    },
    {
      "type": "range",
      "id": "desktop_text_size",
      "label": "Desktop text size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_text_size",
      "label": "Mobile text size",
      "min": 12,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_margin",
      "label": "Title margin bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "description_margin",
      "label": "Description margin bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "select",
      "id": "price_weight",
      "label": "Price weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "price_margin",
      "label": "Price margin bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Match theme colors",
      "info": "Use the theme's color scheme for background, text and button instead of the custom colors below.",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.use_theme_colors }}"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#000000",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description",
      "default": "#666666",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#000000",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Button vertical padding",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Button horizontal padding",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#071e85",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#1a2158",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text",
      "default": "#ffffff",
      "visible_if": "{{ block.settings.use_theme_colors == false }}"
    }
  ],
  "presets": [
    {
      "name": "Horizontal product card"
    }
  ]
}
{% endschema %}