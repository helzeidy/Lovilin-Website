{% doc %}
  @prompt
    Add a global mobile typography control section or snippet that allows adjusting font sizes for all text elements (headings H1–H4, body text, product titles, prices, navigation, buttons) specifically on mobile screens. Use CSS custom properties (variables) and media queries (max-width: 749px) so sizes can be tuned from a single place. Include schema settings with range sliders for each text level so the merchant can control sizes from the theme editor without touching code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mobile-typography-{{ ai_gen_id }} {
    display: block;
  }

  @media screen and (max-width: 749px) {
    :root {
      --mobile-h1-size: {{ block.settings.mobile_h1_size }}px;
      --mobile-h2-size: {{ block.settings.mobile_h2_size }}px;
      --mobile-h3-size: {{ block.settings.mobile_h3_size }}px;
      --mobile-h4-size: {{ block.settings.mobile_h4_size }}px;
      --mobile-body-size: {{ block.settings.mobile_body_size }}px;
      --mobile-product-title-size: {{ block.settings.mobile_product_title_size }}px;
      --mobile-price-size: {{ block.settings.mobile_price_size }}px;
      --mobile-nav-size: {{ block.settings.mobile_nav_size }}px;
      --mobile-button-size: {{ block.settings.mobile_button_size }}px;
    }

    h1,
    .h1 {
      font-size: var(--mobile-h1-size) !important;
    }

    h2,
    .h2 {
      font-size: var(--mobile-h2-size) !important;
    }

    h3,
    .h3 {
      font-size: var(--mobile-h3-size) !important;
    }

    h4,
    .h4,
    h5,
    .h5,
    h6,
    .h6 {
      font-size: var(--mobile-h4-size) !important;
    }

    body,
    p,
    .body-text {
      font-size: var(--mobile-body-size) !important;
    }

    .card__title,
    .product__title,
    .product-card__title {
      font-size: var(--mobile-product-title-size) !important;
    }

    .price,
    .price__regular,
    .price__sale,
    .product__price {
      font-size: var(--mobile-price-size) !important;
    }

    .header__menu-item,
    .menu-drawer__menu-item,
    nav a,
    .navigation-link {
      font-size: var(--mobile-nav-size) !important;
    }

    button,
    .button,
    .btn,
    input[type="submit"] {
      font-size: var(--mobile-button-size) !important;
    }
  }
{% endstyle %}

<div class="ai-mobile-typography-{{ ai_gen_id }}" {{ block.shopify_attributes }}></div>

{% schema %}
{
  "name": "Mobile typography control",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Headings"
    },
    {
      "type": "range",
      "id": "mobile_h1_size",
      "label": "H1 size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_h2_size",
      "label": "H2 size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "mobile_h3_size",
      "label": "H3 size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_h4_size",
      "label": "H4–H6 size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Body and content"
    },
    {
      "type": "range",
      "id": "mobile_body_size",
      "label": "Body text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_product_title_size",
      "label": "Product title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_price_size",
      "label": "Price size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Navigation and buttons"
    },
    {
      "type": "range",
      "id": "mobile_nav_size",
      "label": "Navigation size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_button_size",
      "label": "Button size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Mobile typography control"
    }
  ]
}
{% endschema %}
