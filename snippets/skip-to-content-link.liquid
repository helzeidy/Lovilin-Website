{%- doc -%}
  Renders a skip to content link, visible on focus only.
  Parent element must have position: relative to ensure proper positioning.

  @param {string} href - The URL to skip to, usually an id like "#MainContent".
  @param {string} text - The text to display, in the form of a translation key for a locale file.

  @example
  {% render 'skip-to-content-link', href: '#MainContent', text: 'Skip to main content' %}
{%- enddoc -%}

<a
  class="skip-to-content-link button-secondary"
  href="{{ href }}"
>
  {{ text | t }}
</a>

{% stylesheet %}
  /* Hide off-screen without extending the scrollable area. A physical
     `left: -99999px` is safe in LTR but in RTL the scroll origin flips, so
     the negative offset becomes 99999px of pannable empty space (white void
     you can scroll into on iOS). The clip technique hides it in every
     direction. */
  .skip-to-content-link:not(:focus) {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .skip-to-content-link:focus {
    z-index: var(--layer-temporary);
    overflow: auto;
    width: auto;
    height: auto;
    padding: var(--padding-lg) var(--padding-4xl);
    left: var(--margin-lg);
    top: var(--margin-lg);
    background-color: var(--color-background);
    box-shadow: 0 0 0 var(--focus-outline-offset) var(--color-background);
  }
{% endstylesheet %}
