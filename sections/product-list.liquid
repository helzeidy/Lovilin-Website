

{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture list_items %}
  {% if section.settings.collection != blank and shop.products_count != 0 %}
    {% paginate section.settings.collection.products by max_items %}
      {% for product in section.settings.collection.products limit: max_items %}
        <div class="resource-list__item">
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>

        {% assign banner_pos = section.settings.banner_position | plus: 0 %}
        {% if forloop.index == banner_pos and section.settings.banner_enabled %}
          {% assign overlay_opacity = section.settings.banner_overlay_opacity | divided_by: 100.0 %}
          {% assign overlay_r = section.settings.banner_overlay_color | color_extract: 'red' %}
          {% assign overlay_g = section.settings.banner_overlay_color | color_extract: 'green' %}
          {% assign overlay_b = section.settings.banner_overlay_color | color_extract: 'blue' %}
          <div class="grid-banner-card" style="position: relative; overflow: hidden; border-radius: {{ section.settings.banner_border_radius }}px;">
            {% if section.settings.banner_image %}
              <img
                src="{{ section.settings.banner_image | image_url: width: 600 }}"
                alt="{{ section.settings.banner_heading }}"
                width="600"
                height="800"
                style="width: 100%; height: 100%; object-fit: cover; display: block;">
            {% endif %}
            <div style="position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 20px; background: linear-gradient(to top, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_opacity }}), transparent);">
              {% if section.settings.banner_heading != blank %}
                <h3 style="color: {{ section.settings.banner_text_color }}; margin: 0 0 8px; font-size: {{ section.settings.banner_heading_size }}px; font-weight: {{ section.settings.banner_heading_weight }}; text-transform: {{ section.settings.banner_heading_case }}; line-height: 1.2;">
                  {{ section.settings.banner_heading }}
                </h3>
              {% endif %}
              {% if section.settings.banner_subheading != blank %}
                <p style="color: {{ section.settings.banner_text_color }}; margin: 0 0 12px; font-size: {{ section.settings.banner_description_size }}px; line-height: 1.5; opacity: 0.85;">
                  {{ section.settings.banner_subheading }}
                </p>
              {% endif %}
              {% if section.settings.banner_button_label != blank %}
                <a href="{{ section.settings.banner_button_url }}"
                   style="display: inline-block; padding: 10px 20px; background: {{ section.settings.banner_button_color }}; color: #fff; text-decoration: none; border-radius: {{ section.settings.banner_button_border_radius }}px;">
                  {{ section.settings.banner_button_label }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% unless forloop.last %}
          <!--@list/split-->
        {% endunless %}
      {% endfor %}
    {% endpaginate %}

  {% else %}
    {% for i in (1..max_items) %}
      <div class="resource-list__item">
        {% # theme-check-disable UniqueStaticBlockId %}
          {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
        {% # theme-check-enable UniqueStaticBlockId %}
      </div>

      {% assign banner_pos = section.settings.banner_position | plus: 0 %}
      {% if forloop.index == banner_pos and section.settings.banner_enabled %}
        {% assign overlay_opacity = section.settings.banner_overlay_opacity | divided_by: 100.0 %}
        {% assign overlay_r = section.settings.banner_overlay_color | color_extract: 'red' %}
        {% assign overlay_g = section.settings.banner_overlay_color | color_extract: 'green' %}
        {% assign overlay_b = section.settings.banner_overlay_color | color_extract: 'blue' %}
        <div class="grid-banner-card" style="position: relative; overflow: hidden; border-radius: {{ section.settings.banner_border_radius }}px;">
          {% if section.settings.banner_image %}
            <img
              src="{{ section.settings.banner_image | image_url: width: 600 }}"
              alt="{{ section.settings.banner_heading }}"
              width="600"
              height="800"
              style="width: 100%; height: 100%; object-fit: cover; display: block;">
          {% endif %}
          <div style="position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end; padding: 20px; background: linear-gradient(to top, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_opacity }}), transparent);">
            {% if section.settings.banner_heading != blank %}
              <h3 style="color: {{ section.settings.banner_text_color }}; margin: 0 0 8px; font-size: {{ section.settings.banner_heading_size }}px; font-weight: {{ section.settings.banner_heading_weight }}; text-transform: {{ section.settings.banner_heading_case }}; line-height: 1.2;">
                {{ section.settings.banner_heading }}
              </h3>
            {% endif %}
            {% if section.settings.banner_subheading != blank %}
              <p style="color: {{ section.settings.banner_text_color }}; margin: 0 0 12px; font-size: {{ section.settings.banner_description_size }}px; line-height: 1.5; opacity: 0.85;">
                {{ section.settings.banner_subheading }}
              </p>
            {% endif %}
            {% if section.settings.banner_button_label != blank %}
              <a href="{{ section.settings.banner_button_url }}"
                 style="display: inline-block; padding: 10px 20px; background: {{ section.settings.banner_button_color }}; color: #fff; text-decoration: none; border-radius: {{ section.settings.banner_button_border_radius }}px;">
                {{ section.settings.banner_button_label }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% unless forloop.last %}
        <!--@list/split-->
      {% endunless %}
    {% endfor %}
  {% endif %}
{% endcapture %}




  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>

{% schema %}
{
