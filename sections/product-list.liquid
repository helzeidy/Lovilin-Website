

{% liquid
  assign max_items = section.settings.max_products
%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  data-testid="product-list"
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    section-resource-list
    spacing-style
    gap-style
  "
  style="
    {% render 'spacing-style', settings: section.settings %}
    {% render 'gap-style', value: section.settings.gap %}
  "
>
  <div class="section-resource-list__header">
    {%- content_for 'block', type: '_product-list-content', id: 'static-header' -%}
  </div>

  {% capture banner_card %}
    {%- if section.settings.banner_enabled -%}
      {%- assign overlay_opacity = section.settings.banner_overlay_opacity | divided_by: 100.0 -%}
      {%- assign overlay_r = section.settings.banner_overlay_color | color_extract: 'red' -%}
      {%- assign overlay_g = section.settings.banner_overlay_color | color_extract: 'green' -%}
      {%- assign overlay_b = section.settings.banner_overlay_color | color_extract: 'blue' -%}
      <div class="resource-list__item grid-banner-card" style="position: relative; overflow: hidden; border-radius: {{ section.settings.banner_border_radius }}px;">
        {% if section.settings.banner_image %}
          <img src="{{ section.settings.banner_image | image_url: width: 800 }}" alt="{{ section.settings.banner_heading | escape }}" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;">
        {% endif %}
        <div style="position:relative; display:flex; flex-direction:column; justify-content:flex-end; min-height:340px; height:100%; padding:20px; background:linear-gradient(to top, rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ overlay_opacity }}), transparent);">
          {% if section.settings.banner_heading != blank %}
            <h3 style="color: {{ section.settings.banner_text_color }}; margin: 0 0 8px; font-size: {{ section.settings.banner_heading_size }}px; font-weight: {{ section.settings.banner_heading_weight }}; text-transform: {{ section.settings.banner_heading_case }}; line-height: 1.2;">{{ section.settings.banner_heading }}</h3>
          {% endif %}
          {% if section.settings.banner_subheading != blank %}
            <p style="color: {{ section.settings.banner_text_color }}; margin: 0 0 12px; font-size: {{ section.settings.banner_description_size }}px; line-height: 1.5; opacity: 0.85;">{{ section.settings.banner_subheading }}</p>
          {% endif %}
          {% if section.settings.banner_button_label != blank %}
            <a href="{{ section.settings.banner_button_url }}" style="display: inline-block; padding: 10px 20px; background: {{ section.settings.banner_button_color }}; color: #fff; text-decoration: none; border-radius: {{ section.settings.banner_button_border_radius }}px;">{{ section.settings.banner_button_label }}</a>
          {% endif %}
        </div>
      </div>
    {%- endif -%}
  {% endcapture %}

  {% capture list_items %}
  {% assign banner_pos = section.settings.banner_position | plus: 0 %}
  {% if section.settings.collection != blank and shop.products_count != 0 %}
    {% paginate section.settings.collection.products by max_items %}
      {% for product in section.settings.collection.products limit: max_items %}
        {% if section.settings.banner_enabled and forloop.index == banner_pos %}
          {{ banner_card }}
          <!--@list/split-->
        {% endif %}
        {% assign product_collection_handles = product.collections | map: 'handle' | join: ' ' %}
        <div class="resource-list__item" data-collections="{{ product_collection_handles }}">
          {% # theme-check-disable UniqueStaticBlockId %}
            {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: product %}
          {% # theme-check-enable UniqueStaticBlockId %}
        </div>
        {% unless forloop.last %}<!--@list/split-->{% endunless %}
      {% endfor %}
    {% endpaginate %}
  {% else %}
    {% for i in (1..max_items) %}
      {% if section.settings.banner_enabled and forloop.index == banner_pos %}
        {{ banner_card }}
        <!--@list/split-->
      {% endif %}
      <div class="resource-list__item">
        {% # theme-check-disable UniqueStaticBlockId %}
          {% content_for 'block', type: '_product-card', id: 'static-product-card', closest.product: null %}
        {% # theme-check-enable UniqueStaticBlockId %}
      </div>
      {% unless forloop.last %}<!--@list/split-->{% endunless %}
    {% endfor %}
  {% endif %}
{% endcapture %}




  {% liquid
    # Create an array from the list items to be used for different layout types
    assign list_items_array = list_items | strip | split: '<!--@list/split-->'
  %}

  {% if section.settings.filters_enabled %}
    {% assign filter_collections = section.settings.filter_collections %}
    {% if filter_collections.count > 0 %}
      <div class="product-list-filters" id="filters-{{ section.id }}">
        <button class="product-list-filter-btn active" data-filter="all">All</button>
        {% for fc in filter_collections %}
          <button class="product-list-filter-btn" data-filter="{{ fc.handle }}">{{ fc.title }}</button>
        {% endfor %}
      </div>
      <style>
        #filters-{{ section.id }} {
          display: flex;
          flex-wrap: nowrap;
          gap: {{ section.settings.filter_gap }}px;
          margin-bottom: {{ section.settings.filter_margin_bottom }}px;
          justify-content: safe {{ section.settings.filter_alignment }};
          overflow-x: auto;
          -webkit-overflow-scrolling: touch;
          scroll-snap-type: x proximity;
          scrollbar-width: none;
          -ms-overflow-style: none;
          scroll-padding-inline: {{ section.settings.filter_edge_padding }}px;
          padding-block: 4px;
        }
        /* On mobile, let the tab bar scroll edge-to-edge across the full screen */
        @media (max-width: 749px) {
          #filters-{{ section.id }} {
            width: 100vw;
            max-width: 100vw;
            margin-inline: calc(50% - 50vw);
            padding-inline: calc(var(--util-page-margin-offset, 16px) + {{ section.settings.filter_edge_padding }}px);
            scroll-padding-inline: calc(var(--util-page-margin-offset, 16px) + {{ section.settings.filter_edge_padding }}px);
          }
        }
        #filters-{{ section.id }}::-webkit-scrollbar { display: none; }
        #filters-{{ section.id }} .product-list-filter-btn {
          flex: 0 0 auto;
          white-space: nowrap;
          scroll-snap-align: start;
          padding: {{ section.settings.filter_padding_y }}px {{ section.settings.filter_padding_x }}px;
          border-radius: {{ section.settings.filter_border_radius }}px;
          border: {{ section.settings.filter_border_width }}px solid {{ section.settings.filter_border_color }};
          background: {{ section.settings.filter_bg_color }};
          color: {{ section.settings.filter_text_color }};
          cursor: pointer;
          font-size: {{ section.settings.filter_font_size }}px;
          font-weight: {{ section.settings.filter_font_weight }};
          font-family: inherit;
          transition: background 0.2s, color 0.2s, border-color 0.2s;
        }
        #filters-{{ section.id }} .product-list-filter-btn:hover {
          background: {{ section.settings.filter_hover_bg_color }};
          color: {{ section.settings.filter_hover_text_color }};
          border-color: {{ section.settings.filter_hover_border_color }};
        }
        #filters-{{ section.id }} .product-list-filter-btn.active {
          background: {{ section.settings.filter_active_bg_color }};
          color: {{ section.settings.filter_active_text_color }};
          border-color: {{ section.settings.filter_active_border_color }};
        }
      </style>
      <script>
        (function() {
          var filtersEl = document.getElementById('filters-{{ section.id }}');
          if (!filtersEl) return;
          var sectionEl = filtersEl.closest('[data-testid="product-list"]');
          filtersEl.addEventListener('click', function(e) {
            var btn = e.target.closest('.product-list-filter-btn');
            if (!btn) return;
            filtersEl.querySelectorAll('.product-list-filter-btn').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            var filter = btn.dataset.filter;
            sectionEl.querySelectorAll('.resource-list__item[data-collections]').forEach(function(item) {
              var match = filter === 'all' || item.dataset.collections.split(' ').indexOf(filter) !== -1;
              // Hide the carousel slide wrapper if present, otherwise the item itself (grid)
              var target = item.closest('.resource-list__slide') || item.closest('slideshow-slide') || item;
              target.style.display = match ? '' : 'none';
            });
            // Reset any carousel back to the first visible card
            sectionEl.querySelectorAll('slideshow-slides').forEach(function(track) {
              track.scrollTo({ left: 0, behavior: 'smooth' });
            });
          });
        })();
      </script>
    {% endif %}
  {% endif %}

  {% render 'resource-list',
    list_items: list_items,
    list_items_array: list_items_array,
    settings: section.settings,
    slide_count: max_items,
    content_type: 'products',
    test_id: 'resource-list-grid'
  %}

  <div
    class="section-resource-list__content"
    style="--horizontal-alignment: {{ section.settings.horizontal_alignment }};"
  >
    {%- content_for 'blocks' -%}
  </div>
</div>

{% schema %}
{
  "name": "t:names.product_list",
  "class": "ui-test-product-list",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    },
    {
      "type": "_divider"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:settings.collection"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.layout_type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "carousel",
          "label": "t:options.carousel"
        },
        {
          "value": "editorial",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "carousel_on_mobile",
      "label": "t:settings.carousel_on_mobile",
      "default": false,
      "visible_if": "{{ section.settings.layout_type != 'carousel' }}"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:settings.product_count",
      "min": 1,
      "max": 16,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "t:settings.columns",
      "min": 1,
      "max": 8,
      "step": 1,
      "default": 4,
      "visible_if": "{{ section.settings.layout_type != 'editorial' }}"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "1",
          "label": "t:options.one_number"
        },
        {
          "value": "2",
          "label": "t:options.two_number"
        }
      ],
      "default": "2",
      "visible_if": "{{ section.settings.layout_type == 'grid' and section.settings.carousel_on_mobile == false }}"
    },
    {
      "type": "select",
      "id": "mobile_card_size",
      "label": "t:settings.mobile_columns",
      "options": [
        {
          "value": "85cqw",
          "label": "t:options.one_number"
        },
        {
          "value": "44cqw",
          "label": "t:options.two_number"
        }
      ],
      "default": "85cqw",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid' or section.settings.layout_type == 'carousel' }}"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8,
      "visible_if": "{{ section.settings.layout_type == 'grid'}}"
    },
    {
      "type": "header",
      "content": "t:content.carousel_navigation",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "t:settings.icon",
      "options": [
        {
          "value": "arrow",
          "label": "t:options.arrows"
        },
        {
          "value": "chevron",
          "label": "t:options.chevrons"
        },
        {
          "value": "arrows_large",
          "label": "t:options.arrows_large"
        },
        {
          "value": "chevron_large",
          "label": "t:options.chevron_large"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "arrow",
      "visible_if": "{{ section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "t:settings.icon_background",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "circle",
          "label": "t:options.circle"
        },
        {
          "value": "square",
          "label": "t:options.square"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.icons_style != 'none' and section.settings.layout_type == 'carousel' or section.settings.carousel_on_mobile == true }}"
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "t:settings.alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "t:options.left"
        },
        {
          "value": "center",
          "label": "t:options.center"
        },
        {
          "value": "flex-end",
          "label": "t:options.right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
