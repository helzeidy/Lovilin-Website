              "settings": {
                "heading": "What surfaces can I use the Toy & Surface Cleaner on?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_nYyYQg": {
                  "type": "text",
                  "settings": {
                    "text": "<p>It can be used on toys, highchairs, play areas, tables, and other baby-contact surfaces.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "alignment_mobile": "",
