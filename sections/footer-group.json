              ]
            },
            "accordion_row_gJqW4A": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Why are all Lovilin products fragrance-free?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_pYAi64": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We removed fragrance from every formula to minimize unnecessary ingredients and create products suitable for everyday baby environments.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "alignment_mobile": "",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
