            "accordion_row_WnTQmj": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Are Lovilin products safe for newborns?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_Y9VCEF": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes. All Lovilin products are formulated for use from birth and are designed with baby-safe cleaning in mind.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "alignment_mobile": "",
                    "type_preset": "paragraph",
