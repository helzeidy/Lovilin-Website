              "block_order": [
                "text_pYAi64"
              ]
            },
            "accordion_row_yrFPz7": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What products are included in the Lovilin system?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_6xUAb3": {
                  "type": "text",
                  "settings": {
                    "text": "<p>The Lovilin system includes a Baby Laundry Detergent, an Antibacterial Bottle & Dish Cleanser, an Antibacterial Toy & Surface Cleaner, and an Instant Stain Remover.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "alignment_mobile": "",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
