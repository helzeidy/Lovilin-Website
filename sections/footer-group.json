                "text_dQgKNH"
              ]
            },
            "accordion_row_fw9K3F": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Why do baby bottles need a special cleanser?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_7gnLfF": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Baby bottles can develop milk residue that regular dish soaps may not fully address. Our Bottle & Dish Cleanser is designed specifically for feeding equipment and daily dishes.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "alignment_mobile": "",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
