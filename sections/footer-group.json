            },
            "accordion_row_UF4hQi": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Can I use the Laundry Detergent for the whole family?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_dQgKNH": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Yes. The formula is suitable for baby clothes and everyday family laundry, including whites and colors.</p>",
                    "width": "100%",
                    "max_width": "normal",
                    "alignment": "left",
                    "alignment_mobile": "",
                    "type_preset": "paragraph",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
